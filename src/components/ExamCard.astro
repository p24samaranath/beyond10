---
import type { Exam } from '../lib/data';
import { familyById } from '../lib/data';

interface Props {
  exam: Exam;
}

const { exam } = Astro.props;
const fam = familyById(exam.family);

const nextDate =
  exam.next_dates_2026 && typeof exam.next_dates_2026 === 'object'
    ? Object.values(exam.next_dates_2026)[0]
    : null;
---
<a
  href={`/exams/${exam.id}`}
  data-family={exam.family}
  class="card card-hover group block overflow-hidden"
>
  <div class="fam-stripe h-1"></div>
  <div class="p-5">
    <div class="flex items-start justify-between gap-2">
      <div>
        <h3 class="font-semibold text-slate-900 leading-snug group-hover:text-slate-700">
          {exam.name}
        </h3>
        <p class="text-xs text-slate-500 mt-0.5">{exam.full_name}</p>
      </div>
      {fam && (
        <span class="pill fam-tag font-medium whitespace-nowrap text-[10px]">{fam.name.split(' ')[0]}</span>
      )}
    </div>

    <dl class="mt-4 grid grid-cols-2 gap-3 text-xs">
      <div>
        <dt class="text-slate-500">Next date 2026</dt>
        <dd class="font-semibold text-slate-900 mt-0.5">{nextDate ?? 'TBA'}</dd>
      </div>
      <div>
        <dt class="text-slate-500">Difficulty</dt>
        <dd class="font-semibold text-slate-900 mt-0.5">
          {Array.from({ length: 5 }).map((_, i) => (
            <span class={i < (exam.difficulty_1_to_5 ?? 0) ? 'text-orange-500' : 'text-stone-300'}>●</span>
          ))}
        </dd>
      </div>
    </dl>

    <p class="mt-3 text-xs text-slate-500 line-clamp-2">
      {exam.eligibility}
    </p>
  </div>
</a>

---
import type { Family } from '../lib/data';

interface Props {
  family: Family;
  count?: number;
}

const { family, count } = Astro.props;
---
<a
  href={`/careers?family=${family.id}`}
  data-family={family.id}
  class="card card-hover group block overflow-hidden"
>
  <div class="fam-stripe h-1.5"></div>
  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg font-semibold text-slate-900 group-hover:text-slate-700">
        {family.name}
      </h3>
      <span class="pill fam-tag font-semibold">{count ?? family.career_count} careers</span>
    </div>
    <p class="mt-1.5 text-sm text-slate-500 italic">{family.tagline}</p>
    <p class="mt-3 text-sm text-slate-600 leading-relaxed line-clamp-3">{family.blurb}</p>
    <div class="mt-4 flex items-center justify-between">
      <span class="text-xs text-slate-500">
        {family.entry_streams.join(' · ')}
      </span>
      <span class="text-sm font-medium text-slate-700 group-hover:text-blue-600 inline-flex items-center gap-1">
        Explore
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </span>
    </div>
  </div>
</a>

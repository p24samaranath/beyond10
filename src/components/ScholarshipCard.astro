---
import type { Scholarship } from '../lib/data';

interface Props {
  scholarship: Scholarship;
}

const { scholarship } = Astro.props;

const eligibilityRows: [string, string][] =
  scholarship.eligibility && typeof scholarship.eligibility === 'object'
    ? (Object.entries(scholarship.eligibility as Record<string, unknown>)
        .slice(0, 4)
        .map(([k, v]) => [k, Array.isArray(v) ? v.join(', ') : String(v)]) as [string, string][])
    : [];

const typeColors: Record<string, string> = {
  state: 'bg-emerald-50 text-emerald-700',
  national: 'bg-blue-50 text-blue-700',
  csr: 'bg-amber-50 text-amber-700',
  institutional: 'bg-purple-50 text-purple-700',
  aggregator: 'bg-stone-100 text-stone-700',
};
const typeClass = typeColors[scholarship.type ?? 'national'] ?? typeColors.national;
---
<article class="card p-5">
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-semibold text-slate-900 leading-snug">{scholarship.name}</h3>
    <span class={`pill font-medium uppercase tracking-wide text-[10px] ${typeClass}`}>
      {scholarship.type}
    </span>
  </div>

  {scholarship.amount && (
    <p class="mt-2 text-sm font-semibold text-slate-900">{scholarship.amount}</p>
  )}
  {scholarship.category && (
    <p class="text-xs text-slate-500 mt-0.5">{scholarship.category}</p>
  )}

  {eligibilityRows.length > 0 && (
    <dl class="mt-3 space-y-1 text-xs">
      {eligibilityRows.map(([k, v]) => (
        <div class="flex gap-2">
          <dt class="text-slate-500 capitalize whitespace-nowrap">{k.replace(/_/g, ' ')}:</dt>
          <dd class="text-slate-700 truncate">{v}</dd>
        </div>
      ))}
    </dl>
  )}

  <div class="mt-4 flex items-center justify-between">
    {scholarship.official_url ? (
      <a
        href={scholarship.official_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-blue-600 hover:text-blue-700 inline-flex items-center gap-1"
      >
        Apply
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M7 17L17 7M7 7h10v10"/>
        </svg>
      </a>
    ) : <span></span>}
    {scholarship.source && (
      <span class="text-[10px] text-slate-400">{scholarship.source.split(',')[0]}</span>
    )}
  </div>
</article>

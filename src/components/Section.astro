---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  cta?: { label: string; href: string };
}

const { eyebrow, title, description, align = 'left', cta } = Astro.props;
---
<header class:list={['mb-8', align === 'center' && 'text-center mx-auto max-w-2xl']}>
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-wider text-blue-600 mb-2">{eyebrow}</p>
  )}
  <div class:list={['flex items-end justify-between gap-4', align === 'center' && 'flex-col items-center']}>
    <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">{title}</h2>
    {cta && (
      <a href={cta.href} class="text-sm font-medium text-slate-700 hover:text-slate-900 inline-flex items-center gap-1 whitespace-nowrap">
        {cta.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    )}
  </div>
  {description && (
    <p class="mt-3 text-base text-slate-600 max-w-2xl">{description}</p>
  )}
</header>

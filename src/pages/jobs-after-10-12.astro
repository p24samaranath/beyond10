const pageTitle = "Jobs After 10th & 12th in India — Beyond10";
const pageDescription = "Explore age limits, selection processes, exams, salaries, syllabus, perks, and official application portals for jobs after Class 10 and 12.";
---
<Base title={pageTitle} description={pageDescription}>
  <section class="container-page py-12 sm:py-16">
    <Section
      eyebrow="EARLY CAREER DISCOVERY"
      title="Jobs After Class 10 & 12"
      description="Compare age limits, selection criteria, exam syllabus, salary structures, and official application portals for early career opportunities."
    />

    <!-- Tab switcher -->
    <div class="flex justify-center mb-8">
      <div id="jobs-tabs" class="inline-flex rounded-xl bg-stone-100 p-1 border border-stone-200" role="tablist">
        <button
          type="button"
          class="tab-btn px-4 py-2 text-xs font-semibold rounded-lg bg-slate-900 text-white shadow-sm transition-all"
          data-tab="10"
          role="tab"
          aria-selected="true"
        >
          After Class 10
        </button>
        <button
          type="button"
          class="tab-btn px-4 py-2 text-xs font-semibold rounded-lg text-slate-600 hover:text-slate-900 transition-all"
          data-tab="12"
          role="tab"
          aria-selected="false"
        >
          After Class 12
        </button>
        <button
          type="button"
          class="tab-btn px-4 py-2 text-xs font-semibold rounded-lg text-slate-600 hover:text-slate-900 transition-all"
          data-tab="skills"
          role="tab"
          aria-selected="false"
        >
          Essential Upgrades
        </button>
      </div>
    </div>

    <!-- Section after 10 -->
    <div id="panel-10" class="tab-panel space-y-6">
      <div class="grid gap-6 lg:grid-cols-2">
        {jobs10.map((j) => (
          <div class="card p-6 sm:p-8 flex flex-col justify-between border-slate-200">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class={`text-[10px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full border ${j.sector === 'Government' ? 'bg-amber-50 text-amber-700 border-amber-100' : 'bg-blue-50 text-blue-700 border-blue-100'}`}>
                  {j.sector}
                </span>
                <span class="text-sm font-bold text-slate-900">{j.salary}</span>
              </div>

              <h3 class="text-lg font-bold text-slate-950 mb-2">{j.title}</h3>
              <p class="text-xs text-slate-600 leading-relaxed mb-5">{j.desc}</p>

              <!-- Detailed Candidate Spec Sheet -->
              <div class="grid gap-3 sm:grid-cols-2 text-xs border-t border-b border-stone-100 py-4 mb-5">
                <div>
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">🎂 Age Limits</span>
                  <span class="text-slate-800 font-semibold">{j.age}</span>
                </div>
                <div>
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">🎯 Selection Stage</span>
                  <span class="text-slate-800 font-semibold">{j.selection}</span>
                </div>
                <div class="sm:col-span-2">
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">📚 Exam Syllabus Topics</span>
                  <span class="text-slate-800 font-semibold">{j.syllabus}</span>
                </div>
                <div class="sm:col-span-2">
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">🎁 Allowances & Perks</span>
                  <span class="text-slate-800 font-semibold">{j.perks}</span>
                </div>
              </div>
            </div>

            <!-- Footer Details -->
            <div class="flex flex-wrap items-center justify-between gap-3 text-xs pt-2">
              <div>
                <span class="text-slate-400 block text-[9px] uppercase tracking-wider">Recruiting Body</span>
                <span class="text-slate-700 font-bold">{j.channel}</span>
              </div>
              <div>
                {j.portal.startsWith('http') ? (
                  <a
                    href={j.portal}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-primary px-3 py-1.5 text-[11px]"
                  >
                    Apply Portal ↗
                  </a>
                ) : (
                  <span class="text-stone-400 font-semibold text-[11px] bg-stone-50 border border-stone-200 px-2.5 py-1 rounded-full">
                    {j.portal}
                  </span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Section after 12 -->
    <div id="panel-12" class="tab-panel hidden space-y-6">
      <div class="grid gap-6 lg:grid-cols-2">
        {jobs12.map((j) => (
          <div class="card p-6 sm:p-8 flex flex-col justify-between border-slate-200">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class={`text-[10px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full border ${j.sector === 'Government' ? 'bg-amber-50 text-amber-700 border-amber-100' : 'bg-blue-50 text-blue-700 border-blue-100'}`}>
                  {j.sector}
                </span>
                <span class="text-sm font-bold text-slate-900">{j.salary}</span>
              </div>

              <h3 class="text-lg font-bold text-slate-950 mb-2">{j.title}</h3>
              <p class="text-xs text-slate-600 leading-relaxed mb-5">{j.desc}</p>

              <!-- Detailed Candidate Spec Sheet -->
              <div class="grid gap-3 sm:grid-cols-2 text-xs border-t border-b border-stone-100 py-4 mb-5">
                <div>
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">🎂 Age Limits</span>
                  <span class="text-slate-800 font-semibold">{j.age}</span>
                </div>
                <div>
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">🎯 Selection Stage</span>
                  <span class="text-slate-800 font-semibold">{j.selection}</span>
                </div>
                <div class="sm:col-span-2">
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">📚 Exam Syllabus Topics</span>
                  <span class="text-slate-800 font-semibold">{j.syllabus}</span>
                </div>
                <div class="sm:col-span-2">
                  <span class="font-bold text-slate-500 block uppercase text-[10px] tracking-wider mb-0.5">🎁 Allowances & Perks</span>
                  <span class="text-slate-800 font-semibold">{j.perks}</span>
                </div>
              </div>
            </div>

            <!-- Footer Details -->
            <div class="flex flex-wrap items-center justify-between gap-3 text-xs pt-2">
              <div>
                <span class="text-slate-400 block text-[9px] uppercase tracking-wider">Recruiting Body</span>
                <span class="text-slate-700 font-bold">{j.channel}</span>
              </div>
              <div>
                {j.portal.startsWith('http') ? (
                  <a
                    href={j.portal}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-primary px-3 py-1.5 text-[11px]"
                  >
                    Apply Portal ↗
                  </a>
                ) : (
                  <span class="text-stone-400 font-semibold text-[11px] bg-stone-50 border border-stone-200 px-2.5 py-1 rounded-full">
                    {j.portal}
                  </span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Upgrades section -->
    <div id="panel-skills" class="tab-panel hidden card p-8 max-w-3xl mx-auto space-y-6 border-slate-200">
      <h2 class="text-xl font-bold text-slate-900 border-b border-stone-100 pb-3">How to Escape the Low-Paying Early Career Trap</h2>
      <p class="text-sm text-slate-600 leading-relaxed">
        Starting work early provides financial independence, but it can turn into a dead-end without skill upgrades. Leverage these three foundational skill stacks while working:
      </p>

      <div class="grid gap-6 sm:grid-cols-3">
        <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
          <span class="text-2xl block mb-2">⌨️</span>
          <h3 class="text-sm font-bold text-slate-800 mb-1">Typing Speed</h3>
          <p class="text-xs text-slate-500 leading-relaxed font-semibold">Target 35+ Words Per Minute (WPM) to qualify for state/central government data entry positions.</p>
        </div>
        <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
          <span class="text-2xl block mb-2">📊</span>
          <h3 class="text-sm font-bold text-slate-800 mb-1">Excel & SQL</h3>
          <p class="text-xs text-slate-500 leading-relaxed font-semibold">Learn pivot tables, basic formatting, and queries. Unlocks premium back-office desk assistant jobs.</p>
        </div>
        <div class="p-4 bg-slate-50 rounded-xl border border-slate-100">
          <span class="text-2xl block mb-2">🗣️</span>
          <h3 class="text-sm font-bold text-slate-800 mb-1">Spoken English</h3>
          <p class="text-xs text-slate-500 leading-relaxed font-semibold">Essential to qualify for high-paying international call centers and customer success teams.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Script for tab toggling -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const buttons = document.querySelectorAll<HTMLButtonElement>('#jobs-tabs .tab-btn');
      const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const tab = btn.dataset.tab;
          if (!tab) return;

          buttons.forEach((b) => {
            const selected = b === btn;
            b.setAttribute('aria-selected', selected ? 'true' : 'false');
            b.classList.toggle('bg-slate-900', selected);
            b.classList.toggle('text-white', selected);
            b.classList.toggle('shadow-sm', selected);
            b.classList.toggle('text-slate-600', !selected);
          });

          panels.forEach((p) => {
            p.classList.toggle('hidden', p.id !== `panel-${tab}`);
          });
        });
      });
    });
  </script>
</Base>
